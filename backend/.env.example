# Copy this file to .env for local development.
# .env is gitignored — never commit real credentials.

# SQLite (no Docker needed for local dev / tests)
DATABASE_URL=sqlite+aiosqlite:///./fleet.db
LOG_LEVEL=INFO
# text → human-readable; json → machine-readable (set to json in production/Docker)
LOG_FORMAT=text
CORS_ORIGINS=["http://localhost:5173"]

# PostgreSQL — used automatically by Docker Compose (see docker-compose.yml)
# DATABASE_URL=postgresql+asyncpg://fleet:fleet@localhost:5432/fleet
